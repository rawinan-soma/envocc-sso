# ─── Keycloak Admin ──────────────────────────────────────────────────────────
# The initial admin user created on first boot (change before deploying!)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ─── Rails Database (reserved for Story 3.1) ─────────────────────────────────
RAILS_DB_PASSWORD=change-me

# ─── Keycloak DB Connection (used by compose.yaml) ───────────────────────────
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_db
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-me
