# ─── Keycloak Bootstrap Admin ────────────────────────────────────────────────
# Temporary first-boot admin created by Keycloak on initial startup.
# KC 26 uses KC_BOOTSTRAP_ADMIN_* (KEYCLOAK_ADMIN* is deprecated).
# Change these before deploying to any non-local environment.
KC_BOOTSTRAP_ADMIN_USERNAME=change-me-kc-admin-user
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-kc-admin-password

# ─── PostgreSQL Superuser ─────────────────────────────────────────────────────
# Used by the Postgres container to initialise the cluster.
POSTGRES_USER=change-me-postgres-user
POSTGRES_PASSWORD=change-me-postgres-password

# ─── Keycloak DB Role ─────────────────────────────────────────────────────────
# Least-privilege role that owns only the `keycloak` database.
KC_DB_USERNAME=change-me-kc-db-user
KC_DB_PASSWORD=change-me-kc-db-password

# ─── Admin App DB Role ────────────────────────────────────────────────────────
# Least-privilege role that owns only the `admin` database.
# This role MUST NOT have access to the `keycloak` database.
ADMINAPP_DB_USERNAME=change-me-admin-db-user
ADMINAPP_DB_PASSWORD=change-me-admin-db-password
