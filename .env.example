# ─── Keycloak Admin ──────────────────────────────────────────────────────────
# The initial bootstrap admin user created on first boot.
# Change both values before deploying to any non-local environment.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# ─── Keycloak Hostname ────────────────────────────────────────────────────────
# Hostname Keycloak uses as the base for token issuers, redirect URIs, etc.
# Use 'localhost' for local development; set to your actual FQDN in staging/prod.
KC_HOSTNAME=localhost

# ─── PostgreSQL Superuser ─────────────────────────────────────────────────────
# Superuser credentials for the PostgreSQL container (used by init scripts).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ─── Keycloak DB Connection ───────────────────────────────────────────────────
# Connection details for the keycloak_user role → keycloak_db database.
# The DB name (keycloak_db) must match what 01-init-dbs.sh creates.
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_db
KC_DB_USERNAME=keycloak_user
KC_DB_PASSWORD=change-me

# ─── Admin App DB Connection ──────────────────────────────────────────────────
# Password for the admin_user role → admin database (used by Epic 4 admin app).
# Kept separate from KC_DB_PASSWORD — distinct least-privilege role.
ADMIN_DB_PASSWORD=change-me
