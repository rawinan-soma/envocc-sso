# ─── Keycloak Bootstrap Admin ────────────────────────────────────────────────
# Temporary first-boot admin created by Keycloak on initial startup.
# KC 26 uses KC_BOOTSTRAP_ADMIN_* (KEYCLOAK_ADMIN* is deprecated).
# Change these before deploying to any non-local environment.
KC_BOOTSTRAP_ADMIN_USERNAME=change-me-kc-admin-user
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-kc-admin-password

# ─── PostgreSQL Superuser ─────────────────────────────────────────────────────
# Used by the Postgres container to initialise the cluster.
POSTGRES_USER=change-me-postgres-user
POSTGRES_PASSWORD=change-me-postgres-password

# ─── Keycloak DB Role ─────────────────────────────────────────────────────────
# Least-privilege role that owns only the `keycloak` database.
KC_DB_USERNAME=change-me-kc-db-user
KC_DB_PASSWORD=change-me-kc-db-password

# ─── Admin App DB Role ────────────────────────────────────────────────────────
# Least-privilege role that owns only the `admin` database.
# This role MUST NOT have access to the `keycloak` database.
ADMINAPP_DB_USERNAME=change-me-admin-db-user
ADMINAPP_DB_PASSWORD=change-me-admin-db-password

# ─── Integration Test — ROPC Client Secret ───────────────────────────────────
# Secret for the test-only ROPC client in the envocc realm.
# Used ONLY by integration tests (TS-210d pending-state verification).
# This client and secret must NEVER be deployed to production.
KC_TEST_ROPC_CLIENT_SECRET=change-me-test-secret

# ─── Mock ThaiD IdP — Client Secret (Story 2.9) ──────────────────────────────
# Reserved for the `thaid` identity provider's client credentials once a real
# DOPA/ThaiD secret exists. NOT currently consumed anywhere: no compose
# service or script reads this var, and keycloak/realm-export.json's
# `identityProviders[].config.clientSecret` ships zeroed ("") and stays that
# way — the mock-oauth2-server image used in dev/CI does not validate
# client_secret at all (confirmed hands-on, see keycloak/REALM-EXPORT-NOTES.md,
# Story 2.9 section), so no runtime-population step exists or is needed today.
# Code review finding (Step 7): the previous comment claimed a runtime PUT
# /admin/realms/envocc/identity-provider/instances/thaid population step that
# does not exist in this codebase. A production-hardening pass that repoints
# the `thaid` IdP at real DOPA/ThaiD endpoints will need to add that
# population step (or equivalent) and wire this var into it at that time.
KC_THAID_MOCK_CLIENT_SECRET=change-me-thaid-mock-secret
